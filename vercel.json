{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/static",
  "installCommand": "rm -rf node_modules package-lock.json && npm install --include=dev && npm install --no-save @rollup/rollup-linux-x64-gnu",
  "rewrites": [
    {
      "source": "/assets/(.*)",
      "destination": "/assets/$1"
    },
    {
      "source": "/__manus__/(.*)",
      "destination": "/__manus__/$1"
    },
    {
      "source": "/pdf.worker.min.mjs",
      "destination": "/pdf.worker.min.mjs"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/handler"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
